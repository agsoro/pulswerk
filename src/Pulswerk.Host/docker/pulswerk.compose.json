{
  // ── InfluxDB ─────────────────────────────────────────────────────────────
  // "influxdb" resolves to the sibling container on the compose network.
  "influxdb": {
    "url": "http://influxdb:8086",
    "token": "connector-token",
    "org": "pulswerk",
    "bucket": "telemetry"
  },
  "database": {
    "retentionDays": 730,
    "compactionAfterDays": 700,
    "alarmRetentionDays": 30
  },
  "polling": {
    "intervalSeconds": 30
  },
  // ── Monitoring Dashboard ──────────────────────────────────────────────────
  "monitoring": {
    "enabled": true,
    "port": 5000,
    "logBufferSize": 5000
  },
  // ── Connections ──────────────────────────────────────────────────────────
  "connections": [
    {
      "id": "modbus-test",
      "type": "modbus-tcp",
      "address": "modbus-sim",
      "port": 502,
      "name": "Modbus Sim 1"
    },
    {
      "id": "modbus-test2",
      "type": "modbus-tcp",
      "address": "modbus-sim2",
      "port": 502,
      "name": "Modbus Sim 2"
    },
    {
      "id": "bacnet-deziko",
      "type": "bacnet-ip",
      "localAddress": "0.0.0.0",
      "localPort": 47809, // different from simulator
      "localDeviceId": 1234,
      "name": "Deziko BACnet"
    }
  ],
  // ── Devices ──────────────────────────────────────────────────────────────
  "devices": [
    {
      "id": "meter-main-a",
      "name": "Main Meter Building A",
      "deviceType": "janitza",
      "connectionId": "modbus-test",
      "deviceId": 1,
      "pollIntervalSeconds": 30,
      "path": [
        "Building A",
        "Main Meter Building A"
      ],
      "assetType": "Meter"
    },
    {
      "id": "meter-sub-f2",
      "name": "Sub Meter Floor 2",
      "deviceType": "janitza",
      "connectionId": "modbus-test",
      "deviceId": 2,
      "pollIntervalSeconds": 30,
      "path": [
        "Building A",
        "Floor 2",
        "Sub Meter Floor 2"
      ],
      "assetType": "Meter"
    },
    {
      "id": "meter-sub-f3",
      "name": "Sub Meter Floor 3",
      "deviceType": "janitza",
      "connectionId": "modbus-test2",
      "deviceId": 1,
      "pollIntervalSeconds": 30,
      "path": [
        "Building A",
        "Floor 3",
        "Sub Meter Floor 3"
      ],
      "assetType": "Meter"
    },
    {
      "id": "meter-hvac",
      "name": "HVAC Meter",
      "deviceType": "janitza",
      "connectionId": "modbus-test2",
      "deviceId": 2,
      "pollIntervalSeconds": 30,
      "path": [
        "Building A",
        "HVAC",
        "HVAC Meter"
      ],
      "assetType": "Meter"
    },
    {
      "id": "ahu-test-bacnet",
      "name": "Test BACnet AHU",
      "deviceType": "deziko",
      "connectionId": "bacnet-deziko",
      "deviceId": 10,
      "address": "bacnet-sim",
      "assetType": "BACnet Zone"
    }
  ],
  "unitTranslations": {
    "degrees celsius": "°C",
    "degrees kelvin": "°C",
    "percent": "%",
    "pascals": "Pa",
    "percent relative humidity": "% r.F.",
    "cubic meters per hour": "m³/h",
    "liters per second": "l/s",
    "no units": ""
  }
}