{
  "influxdb": {
    "url": "http://localhost:8086",
    "token": "connector-token",
    "org": "pulswerk",
    "bucket": "telemetry"
  },
  "database": {
    "retentionDays": 730,
    "compactionAfterDays": 700,
    "alarmRetentionDays": 30
  },
  "polling": {
    "intervalSeconds": 30
  },
  "connections": [
    {
      "id": "modbus-building-a",
      "type": "modbus-tcp",
      "address": "192.168.1.100",
      "port": 502
    },
    {
      "id": "modbus-building-b",
      "type": "modbus-tcp",
      "address": "192.168.1.101",
      "port": 502
    },
    {
      "id": "bacnet-deziko",
      "type": "bacnet-ip",
      "localAddress": "0.0.0.0",
      "localPort": 47808,
      "localDeviceId": 1234
    }
  ],
  "devices": [
    {
      "id": "meter-main-a",
      "name": "Main Meter Building A",
      "deviceType": "janitza",
      "connectionId": "modbus-building-a",
      "deviceId": 1
    },
    {
      "id": "meter-sub-f2",
      "name": "Sub Meter Floor 2",
      "deviceType": "janitza",
      "connectionId": "modbus-building-b",
      "deviceId": 1
    },
    {
      "id": "meter-sub-f3",
      "name": "Sub Meter Floor 3",
      "deviceType": "janitza",
      "connectionId": "modbus-building-b",
      "deviceId": 2
    },
    {
      "id": "meter-main",
      "name": "Main Meter",
      "deviceType": "janitza",
      "connectionId": "modbus-building-a",
      "deviceId": 10,
      "path": [
        "Building",
        "Main Meter"
      ],
      "assetType": "Meter"
    },
    {
      "id": "meter-sub",
      "name": "Sub Meter",
      "deviceType": "janitza",
      "connectionId": "modbus-building-a",
      "deviceId": 11,
      "path": [
        "Building",
        "Main Meter",
        "Sub Meter"
      ],
      "assetType": "Meter"
    },
    {
      "id": "meter-floor",
      "name": "Floor Meter",
      "deviceType": "janitza",
      "connectionId": "modbus-building-a",
      "deviceId": 12,
      "path": [
        "Building",
        "Main Meter",
        "Sub Meter",
        "Floor Meter"
      ],
      "assetType": "Meter Level"
    },
    {
      "id": "ctrl-zone-1",
      "name": "Glueck Controller Zone 1",
      "deviceType": "glueck",
      "connectionId": "modbus-building-a",
      "deviceId": 3
    },
    {
      "id": "asp01",
      "name": "ASP01",
      "deviceType": "deziko",
      "connectionId": "bacnet-deziko",
      "deviceId": 10,
      "assetType": "BACnet Node",
      "filter": {
        "excludeNamePattern": "^(UNUSED|SPARE|TEST)"
      }
    },
    {
      "id": "ahu-test-bacnet",
      "name": "Test BACnet AHU",
      "deviceType": "deziko",
      "connectionId": "bacnet-deziko",
      "deviceId": 20,
      "assetType": "BACnet Zone"
    }
  ],
  "server": {
    "port": 5000,
    "logBufferSize": 5000,
    "auth": {
      "enabled": true,
      // IP addresses or CIDR ranges of reverse proxies (nginx/Authelia).
      // Remote-User/Groups/Name/Email headers are ONLY trusted from these sources.
      // When disabled, auth headers are stripped from ALL requests (safe default).
      "trustedProxies": ["10.192.30.1"],
      // Fallback user/groups if no authentication headers are present.
      "defaultUser": "operator",
      "defaultGroups": ["operators"]
    },
    // Role-based access control for write operations.
    "rights": {
      "enabled": true,
      // Groups allowed to change telemetry values (write-back).
      "allowAssetValueEdit": ["users", "admins"],
      // Groups allowed to acknowledge alarms.
      "allowAlarmAck": ["users", "admins"],
      // Groups allowed to edit dashboards (create, save, delete).
      "allowDashboardEdit": ["admins"],
      // Groups allowed to pin/unpin favorites.
      "allowFavoriteEdit": ["users", "admins"]
    }
  }
}