@page
@model Pulswerk.Dashboard.Pages.ConnectionsModel
@{
    ViewData["Title"] = "Connections";
}


<div class="flex gap-6 h-[calc(100vh-110px)] animate-fade-in" data-testid="conn-layout">

    <!-- ── Left: connection cards ── -->
    <div class="w-[300px] shrink-0 flex flex-col gap-3 overflow-y-auto pr-1 conn-list" id="connList" data-testid="conn-list">
        @foreach (var conn in Model.Connections)
        {
            int online = conn.Devices.Count(d => d.Status == "online");
            int stale = conn.Devices.Count(d => d.Status == "stale");
            int offline = conn.Devices.Count(d => d.Status == "offline");
            <div class="conn-card glass p-4 rounded-xl border border-slate-700 cursor-pointer transition-all duration-150 flex flex-col gap-1.5 select-none hover:border-sky-400 hover:bg-sky-400/5"
                 data-id="@conn.Id"
                 onclick="selectConnection('@conn.Id')">
                <div class="flex justify-between items-start">
                    <div class="font-bold text-[0.95rem] text-slate-50">@conn.Name</div>
                    <span class="text-[0.65rem] font-bold uppercase tracking-wide px-2 py-0.5 rounded bg-white/5 text-slate-400 whitespace-nowrap">@conn.Type</span>
                </div>
                <div class="text-[0.78rem] text-slate-400 font-mono">@conn.Address : @conn.Port</div>
                <div class="flex justify-between items-center mt-0.5">
                    <span class="text-xs font-semibold flex items-center @(conn.Status == "online" ? "text-emerald-500" : conn.Status == "stale" ? "text-amber-400" : "text-red-500")">
                        <span class="w-[7px] h-[7px] rounded-full mr-1.5 inline-block @(conn.Status == "online" ? "bg-emerald-500" : conn.Status == "stale" ? "bg-amber-400" : "bg-red-500")"></span>
                        @conn.Status.ToUpper()
                    </span>
                    <div class="flex items-center gap-1.5 text-[0.72rem] font-bold">
                        <span class="text-emerald-400">@online</span>
                        @if (stale > 0) { <span class="text-amber-400">@stale</span> }
                        @if (offline > 0) { <span class="text-red-400">@offline</span> }
                        <span class="text-slate-500 font-normal">/ @conn.DeviceCount</span>
                    </div>
                </div>
            </div>
        }
        @if (Model.CanEditConfig)
        {
            <div class="mt-auto pt-4">
                <div class="conn-card glass p-3.5 rounded-xl border border-amber-500/20 cursor-pointer transition-all duration-150 flex items-center justify-center gap-2 select-none hover:border-amber-400 hover:bg-amber-400/10 text-amber-400 font-bold" id="btnEditConfig" onclick="selectConfig()">
                    <i class="fas fa-cog"></i> Edit Configuration
                </div>
            </div>
        }
    </div>

    <!-- ── Right: detail panel ── -->
    <div class="flex-1 flex flex-col gap-4 overflow-hidden" data-testid="conn-detail">

        <!-- placeholder shown when nothing is selected -->
        <div class="flex-1 flex flex-col items-center justify-center gap-4 text-slate-400 opacity-45 text-sm" id="detailEmpty" data-testid="conn-detail-empty">
            <i class="fas fa-network-wired text-4xl"></i>
            <p>Select a connection to view its devices</p>
        </div>

        <div class="flex-1 overflow-y-auto" id="panel-config" style="display:none;">
            <div id="config-root" class="h-full w-full"></div>
        </div>

        <!-- per-connection panels, hidden until selected -->
        @foreach (var conn in Model.Connections)
        {
            <div class="flex-1 flex flex-col bg-slate-800 border border-slate-700 rounded-xl overflow-hidden" id="panel-@conn.Id" style="display:none;">
                <div class="px-6 py-5 border-b border-slate-700 flex justify-between items-center shrink-0 bg-black/15">
                    <div>
                        <div class="text-lg font-bold text-slate-50">@conn.Name</div>
                        <div class="text-[0.78rem] text-slate-400 font-mono mt-0.5">@conn.Address : @conn.Port &nbsp;·&nbsp; @conn.Type &nbsp;·&nbsp; @conn.Id</div>
                    </div>
                    <div class="flex gap-6 items-center">
                        <div class="text-right">
                            <div class="text-xl font-bold text-sky-400 leading-tight">@conn.DeviceCount</div>
                            <div class="text-[0.65rem] uppercase tracking-wider text-slate-400">Devices</div>
                        </div>
                        <div class="text-right">
                            <div class="text-xl font-bold leading-tight @(conn.Status == "online" ? "text-emerald-500" : conn.Status == "stale" ? "text-amber-400" : "text-red-500")">
                                @conn.Status.ToUpper()
                            </div>
                            <div class="text-[0.65rem] uppercase tracking-wider text-slate-400">Status</div>
                        </div>
                    </div>
                </div>

                <!-- ── Health chart ── -->
                <div class="px-6 py-5 border-b border-slate-700/50 shrink-0">
                    <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-2 text-sm font-semibold text-slate-300">
                            <i class="fas fa-heartbeat text-emerald-500 text-xs"></i>
                            Device Availability
                        </div>
                        <div class="text-[0.65rem] font-bold text-slate-500 uppercase tracking-widest bg-white/5 px-2 py-0.5 rounded">24h · 5 min intervals</div>
                    </div>
                    <div class="h-[110px] health-chart" id="health-chart-@conn.Id"
                         data-conn-id="@conn.Id" data-total="@conn.DeviceCount"></div>
                </div>

                <div class="flex-1 overflow-y-auto px-6 py-4 device-table-wrap">
                    @if (conn.Devices.Count == 0)
                    {
                        <div class="py-8 text-center text-slate-400 opacity-50">
                            No devices configured on this connection.
                        </div>
                    }
                    else
                    {
                        <table class="w-full border-separate border-spacing-0 text-sm">
                            <thead>
                                <tr>
                                    <th class="px-3 py-2.5 text-left text-[0.68rem] font-bold uppercase tracking-wider text-slate-400 border-b border-slate-700 whitespace-nowrap">Device</th>
                                    <th class="px-3 py-2.5 text-left text-[0.68rem] font-bold uppercase tracking-wider text-slate-400 border-b border-slate-700 whitespace-nowrap">Protocol</th>
                                    <th class="px-3 py-2.5 text-left text-[0.68rem] font-bold uppercase tracking-wider text-slate-400 border-b border-slate-700 whitespace-nowrap">Address</th>
                                    <th class="px-3 py-2.5 text-left text-[0.68rem] font-bold uppercase tracking-wider text-slate-400 border-b border-slate-700 whitespace-nowrap">Asset Type</th>
                                    <th class="px-3 py-2.5 text-left text-[0.68rem] font-bold uppercase tracking-wider text-slate-400 border-b border-slate-700 whitespace-nowrap">Status</th>
                                    <th class="px-3 py-2.5 text-left text-[0.68rem] font-bold uppercase tracking-wider text-slate-400 border-b border-slate-700 whitespace-nowrap">Last Seen</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var dev in conn.Devices)
                                {
                                    <tr class="transition-colors duration-150 hover:bg-white/[0.03]">
                                        <td class="px-3 py-3 border-b border-white/[0.04] align-middle">
                                            <div class="font-semibold">@dev.Name</div>
                                            <div class="text-[0.72rem] text-slate-400 mt-0.5">@dev.DeviceType</div>
                                        </td>
                                        <td class="px-3 py-3 border-b border-white/[0.04] align-middle">
                                            <span class="dev-type-pill inline-block text-[0.68rem] font-bold uppercase tracking-wide px-2 py-0.5 rounded-full bg-sky-400/10 text-sky-400 border border-sky-400/20 @dev.Protocol.ToLower()">@dev.Protocol</span>
                                        </td>
                                        <td class="px-3 py-3 border-b border-white/[0.04] align-middle font-mono text-[0.82rem]">@dev.Address</td>
                                        <td class="px-3 py-3 border-b border-white/[0.04] align-middle">
                                            @if (!string.IsNullOrEmpty(dev.AssetType))
                                            {
                                                <span class="inline-block text-[0.68rem] px-2 py-0.5 rounded bg-white/5 text-slate-400 font-mono">@dev.AssetType</span>
                                            }
                                            else
                                            {
                                                <span class="text-slate-400 opacity-40">–</span>
                                            }
                                        </td>
                                        <td class="px-3 py-3 border-b border-white/[0.04] align-middle">
                                            <div class="flex items-center gap-1.5 text-[0.78rem] font-semibold @(dev.Status == "online" ? "text-emerald-500" : dev.Status == "stale" ? "text-amber-400" : "text-red-500")">
                                                <span class="w-[7px] h-[7px] rounded-full inline-block @(dev.Status == "online" ? "bg-emerald-500" : dev.Status == "stale" ? "bg-amber-400" : "bg-red-500")"></span>
                                                @dev.Status.ToUpper()
                                            </div>
                                        </td>
                                        <td class="px-3 py-3 border-b border-white/[0.04] align-middle text-[0.78rem] font-mono text-slate-400">@dev.LastSeen</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
<script>
    let activeId = null;
    const healthCharts = {};

    function selectConnection(id) {
        if (activeId) {
            document.querySelector(`.conn-card[data-id="${activeId}"]`)?.classList.remove('active');
            const old = document.getElementById('panel-' + activeId);
            if (old) old.style.display = 'none';
        }
        const btnEditConfig = document.getElementById('btnEditConfig');
        if (btnEditConfig) btnEditConfig.classList.remove('active');
        const configPanel = document.getElementById('panel-config');
        if (configPanel) configPanel.style.display = 'none';

        activeId = id;
        document.querySelector(`.conn-card[data-id="${id}"]`)?.classList.add('active');
        document.getElementById('detailEmpty').style.display = 'none';
        const panel = document.getElementById('panel-' + id);
        if (panel) panel.style.display = 'flex';

        const url = new URL(window.location);
        url.searchParams.set('conn', id);
        history.replaceState({}, '', url);

        loadHealthChart(id);
    }

    function selectConfig() {
        if (activeId) {
            document.querySelector(`.conn-card[data-id="${activeId}"]`)?.classList.remove('active');
            const old = document.getElementById('panel-' + activeId);
            if (old) old.style.display = 'none';
        }
        activeId = 'config';
        document.getElementById('btnEditConfig').classList.add('active');
        document.getElementById('detailEmpty').style.display = 'none';
        document.getElementById('panel-config').style.display = 'block';

        const url = new URL(window.location);
        url.searchParams.set('conn', 'config');
        history.replaceState({}, '', url);
    }

    async function loadHealthChart(connId) {
        const el = document.getElementById('health-chart-' + connId);
        if (!el) return;

        const total = parseInt(el.dataset.total) || 1;

        try {
            const res = await fetch(`/plswk/api/connection-health/${encodeURIComponent(connId)}`);
            const data = await res.json();

            const onlineSeries = data.map(d => ({
                x: new Date(d.t).getTime(),
                y: d.online
            }));

            const offlineSeries = data.map(d => ({
                x: new Date(d.t).getTime(),
                y: d.total - d.online
            }));

            if (healthCharts[connId]) {
                healthCharts[connId].destroy();
            }

            const options = {
                series: [
                    { name: 'Online', data: onlineSeries },
                    { name: 'Offline', data: offlineSeries }
                ],
                chart: {
                    type: 'area',
                    height: '100%',
                    stacked: true,
                    animations: { enabled: true, easing: 'easeinout', speed: 400 },
                    toolbar: { show: false },
                    zoom: { enabled: false }
                },
                colors: ['#10b981', '#ef4444'],
                fill: {
                    type: 'gradient',
                    gradient: {
                        shadeIntensity: 1,
                        opacityFrom: 0.5,
                        opacityTo: 0.08,
                        stops: [10, 100]
                    }
                },
                stroke: { curve: 'stepline', width: 2 },
                legend: {
                    show: true,
                    position: 'top',
                    horizontalAlign: 'right',
                    labels: { colors: '#94a3b8' },
                    markers: { width: 8, height: 8, radius: 4 },
                    fontSize: '11px',
                    fontFamily: 'inherit'
                },
                grid: {
                    borderColor: 'rgba(255,255,255,0.06)',
                    xaxis: { lines: { show: false } },
                    yaxis: { lines: { show: true } },
                    padding: { bottom: 0, left: 6, right: 6, top: 0 }
                },
                xaxis: {
                    type: 'datetime',
                    labels: {
                        style: { colors: '#64748b', fontSize: '10px' },
                        datetimeUTC: false,
                        datetimeFormatter: { hour: 'HH:mm', day: 'dd MMM' }
                    },
                    axisBorder: { show: true, color: 'rgba(255,255,255,0.08)' },
                    axisTicks: { show: false }
                },
                yaxis: {
                    min: 0,
                    max: total,
                    forceNiceScale: false,
                    tickAmount: Math.min(total, 5),
                    labels: {
                        style: { colors: '#64748b', fontSize: '10px' },
                        formatter: (v) => Math.round(v).toString()
                    },
                    title: { text: 'devices', style: { color: '#475569', fontSize: '11px' } }
                },
                dataLabels: { enabled: false },
                tooltip: {
                    theme: 'dark',
                    shared: true,
                    intersect: false,
                    x: { format: 'dd MMM HH:mm' },
                    y: { formatter: (val) => val + ' device' + (val !== 1 ? 's' : '') }
                },
                noData: {
                    text: 'Collecting data\u2026 (first sample in ~5 min)',
                    align: 'center',
                    style: { color: '#475569', fontSize: '13px' }
                }
            };

            const chart = new ApexCharts(el, options);
            chart.render();
            healthCharts[connId] = chart;
        } catch (e) {
            console.error('Failed to load health chart:', e);
        }
    }

    // Auto-refresh the active chart every 5 minutes
    setInterval(() => {
        if (activeId) loadHealthChart(activeId);
    }, 5 * 60_000);

    // Restore selection from URL on load
    window.addEventListener('DOMContentLoaded', () => {
        const params = new URLSearchParams(window.location.search);
        const conn = params.get('conn');
        if (conn === 'config' && document.getElementById('btnEditConfig')) {
            selectConfig();
        } else if (conn && document.querySelector(`.conn-card[data-id="${conn}"]`)) {
            selectConnection(conn);
        } else {
            const first = document.querySelector('.conn-card');
            if (first && document.querySelectorAll('.conn-card').length === 1) {
                selectConnection(first.dataset.id);
            }
        }
    });
</script>
    <environment include="Development">
        <script src="/plswk/js/pages/config.page.js" type="module"></script>
    </environment>
    <environment exclude="Development">
        <script src="/plswk/dist/js/config.page.bundle.js" type="module"></script>
    </environment>
}
