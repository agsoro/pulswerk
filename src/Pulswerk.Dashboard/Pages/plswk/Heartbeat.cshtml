@page
@model Pulswerk.Dashboard.Pages.HeartbeatModel
@{
    ViewData["Title"] = "System Heartbeat";
}

<div class="flex items-center justify-between mb-8 animate-fade-in">
    <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-white" data-i18n="system_heartbeat">System Heartbeat</h1>
        <p class="text-slate-400 mt-1" data-i18n="system_heartbeat_desc">Real-time health monitoring and performance statistics.</p>
    </div>
    <div class="flex items-center gap-3 bg-white/5 px-4 py-2 rounded-xl border border-white/10" id="statusBadge">
        @if (Model.Stats.IsScanning) {
            <div class="w-3 h-3 rounded-full bg-amber-500 animate-pulse"></div>
            <span class="text-sm font-medium text-amber-400 uppercase tracking-wider" data-i18n="scanning">Scanning Discovery/History...</span>
        } else {
            <div class="w-3 h-3 rounded-full bg-emerald-500 animate-pulse"></div>
            <span class="text-sm font-medium text-emerald-400 uppercase tracking-wider" data-i18n="system_operational">System Operational</span>
        }
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8 animate-slide-up">
    <!-- Uptime -->
    <div class="bg-slate-800/50 border border-white/10 p-6 rounded-2xl shadow-xl">
        <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 bg-indigo-500/20 text-indigo-400 rounded-xl flex items-center justify-center">
                <i class="fas fa-clock text-xl"></i>
            </div>
            <span class="text-[0.65rem] font-bold text-slate-500 uppercase tracking-widest" data-i18n="uptime">Uptime</span>
        </div>
        <div class="text-3xl font-bold text-white tracking-tight" id="uptime">@FormatUptime(Model.Stats.UptimeSeconds)</div>
    </div>

    <!-- Updates/min -->
    <div class="bg-slate-800/50 border border-white/10 p-6 rounded-2xl shadow-xl">
        <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 bg-emerald-500/20 text-emerald-400 rounded-xl flex items-center justify-center">
                <i class="fas fa-bolt text-xl"></i>
            </div>
            <span class="text-[0.65rem] font-bold text-slate-500 uppercase tracking-widest" data-i18n="updates_min">Updates / Min</span>
        </div>
        <div class="text-3xl font-bold text-white tracking-tight" id="upm">@Model.Stats.UpdatesPerMinute.ToString("F1")</div>
    </div>

    <!-- Data Points -->
    <div class="bg-slate-800/50 border border-white/10 p-6 rounded-2xl shadow-xl">
        <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 bg-sky-500/20 text-sky-400 rounded-xl flex items-center justify-center">
                <i class="fas fa-database text-xl"></i>
            </div>
            <span class="text-[0.65rem] font-bold text-slate-500 uppercase tracking-widest" data-i18n="points">Total Points</span>
        </div>
        <div class="text-3xl font-bold text-white tracking-tight" id="points">@Model.Stats.TotalTelemetries.ToString("N0")</div>
    </div>

    <!-- DB Size -->
    <div class="bg-slate-800/50 border border-white/10 p-6 rounded-2xl shadow-xl">
        <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 bg-amber-500/20 text-amber-400 rounded-xl flex items-center justify-center">
                <i class="fas fa-hdd text-xl"></i>
            </div>
            <span class="text-[0.65rem] font-bold text-slate-500 uppercase tracking-widest" data-i18n="storage">Storage Size</span>
        </div>
        <div class="text-3xl font-bold text-white tracking-tight" id="dbSize">
            @if (Model.Stats.DatabaseSizeBytes > 1024 * 1024 * 1024) {
                @((Model.Stats.DatabaseSizeBytes / (1024.0 * 1024.0 * 1024.0)).ToString("F2")) @:GB
            } else {
                @((Model.Stats.DatabaseSizeBytes / (1024.0 * 1024.0)).ToString("F2")) @:MB
            }
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 animate-slide-up" style="animation-delay: 0.1s">
    <!-- System Info -->
    <div class="lg:col-span-1 bg-slate-800/50 border border-white/10 rounded-2xl shadow-xl overflow-hidden">
        <div class="p-6 border-b border-white/5 bg-white/[0.02]">
            <h3 class="text-lg font-bold text-white flex items-center gap-2" data-i18n="system_info">
                <i class="fas fa-server text-slate-500"></i> System Information
            </h3>
        </div>
        <div class="p-6 space-y-4">
            <div class="flex justify-between">
                <span class="text-slate-400" data-i18n="version">Software Version</span>
                <span class="text-white font-medium">@Model.Stats.Version</span>
            </div>
            <div class="flex justify-between">
                <span class="text-slate-400" data-i18n="environment">Environment</span>
                <span class="text-white font-medium" data-i18n="production">Production</span>
            </div>
            <div class="flex justify-between">
                <span class="text-slate-400">Devices</span>
                <span class="text-white font-medium">
                    <span class="text-emerald-400">@Model.Stats.OnlineDevices</span>
                    @if (Model.Stats.StaleDevices > 0) {<span class="text-amber-400">/ @Model.Stats.StaleDevices stale</span>}
                    @if (Model.Stats.OfflineDevices > 0) {<span class="text-red-400">/ @Model.Stats.OfflineDevices off</span>}
                    <span class="text-slate-500">/ @Model.Stats.TotalDevices</span>
                </span>
            </div>
            <div class="flex justify-between">
                <span class="text-slate-400" data-i18n="data_point_keys">Data Point Keys</span>
                <span class="text-white font-medium">@Model.Stats.TotalTelemetryKeys.ToString("N0")</span>
            </div>
            <div class="flex justify-between border-t border-white/5 pt-4">
                <span class="text-slate-400">Memory (RSS / GC)</span>
                <span class="text-white font-medium" id="memStats">@Model.Stats.WorkingSetMb MB / @Model.Stats.GcHeapMb MB</span>
            </div>
            <div class="flex justify-between">
                <span class="text-slate-400">TCP Connections (pooled)</span>
                <span class="text-white font-medium" id="tcpConns">@Model.Stats.TcpConnections</span>
            </div>
            @if (Model.Stats.OldestDeviceSeenUtc != null) {
            <div class="flex justify-between">
                <span class="text-slate-400">Oldest Device Seen</span>
                <span class="text-white font-medium text-[0.78rem] font-mono" id="oldestSeen">@Model.Stats.OldestDeviceSeenUtc UTC</span>
            </div>
            }
            <div class="flex justify-between border-t border-white/5 pt-4">
                <span class="text-slate-400" data-i18n="total_updates_processed">Total updates</span>
                <span class="text-white font-medium" id="totalUpdates">@Model.Stats.TotalUpdates.ToString("N0")</span>
            </div>
            <div class="flex justify-between text-sm">
                <span class="text-slate-500 pl-3 flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-violet-500 inline-block"></span> Push (COV)
                </span>
                <span class="text-slate-300 font-medium font-mono" id="totalPush">@Model.Stats.TotalPushUpdates.ToString("N0")</span>
            </div>
            <div class="flex justify-between text-sm">
                <span class="text-slate-500 pl-3 flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span> Pull (Poll)
                </span>
                <span class="text-slate-300 font-medium font-mono" id="totalPull">@Model.Stats.TotalPullUpdates.ToString("N0")</span>
            </div>
        </div>
    </div>

    <!-- Live Update Graph -->
    <div class="lg:col-span-2 bg-slate-800/50 border border-white/10 rounded-2xl shadow-xl p-6">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-bold text-white flex items-center gap-2" data-i18n="update_throughput">
                <i class="fas fa-chart-line text-slate-500"></i> Update Throughput
            </h3>
            <div class="text-[0.7rem] font-bold text-slate-500 uppercase tracking-widest bg-white/5 px-2 py-1 rounded" data-i18n="live_window">Live (60s window)</div>
        </div>
        <div class="h-[480px] border border-white/5 rounded-xl p-2" id="throughputChart">
        </div>
    </div>
</div>


@functions {
    string FormatUptime(long seconds) {
        var t = TimeSpan.FromSeconds(seconds);
        if (t.TotalDays >= 1) return $"{(int)t.TotalDays}d {t.Hours}h {t.Minutes}m";
        if (t.TotalHours >= 1) return $"{t.Hours}h {t.Minutes}m {t.Seconds}s";
        return $"{t.Minutes}m {t.Seconds}s";
    }
}

@section Scripts {
    <environment include="Development">
        <script src="/plswk/js/pages/heartbeat.page.js" type="module"></script>
    </environment>
    <environment exclude="Development">
        <script src="/plswk/dist/js/heartbeat.page.bundle.js" type="module"></script>
    </environment>
    <script type="module">
        initHeartbeatPage({
            totalPush: @Model.Stats.TotalPushUpdates,
            totalPull: @Model.Stats.TotalPullUpdates
        });
    </script>
}
