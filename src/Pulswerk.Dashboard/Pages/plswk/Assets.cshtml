@page
@model Pulswerk.Dashboard.Pages.AssetsModel
@{
    ViewData["Title"] = "Assets";
}


<div class="flex h-[calc(100vh-110px)] border border-slate-700 rounded-xl overflow-hidden animate-fade-in">
    <!-- Left Sidebar: The Asset Tree -->
    <div class="asset-sidebar full-width w-[320px] min-w-[250px] border-r border-slate-700 bg-black/10 overflow-y-auto py-4 flex flex-col transition-all duration-300" id="assetTree">
        <div class="h-full flex flex-col items-center justify-center text-slate-400 opacity-50 py-8">
            <i class="fas fa-spinner fa-spin text-5xl mb-4"></i>
            <p data-i18n="loading_tree">Loading tree...</p>
        </div>
    </div>

    <!-- Splitter -->
    <div class="w-1 bg-slate-700 cursor-col-resize transition-colors duration-200 hover:bg-sky-400 resizer" id="dragMe" style="display: none;"></div>

    <!-- Right Content: Points for selected node -->
    <div class="flex-1 flex flex-col overflow-hidden asset-content hidden">
        <div id="contentView" style="display: none; height: 100%; flex-direction: column;">
            <div class="px-6 py-5 border-b border-slate-700 bg-white/[0.02]">
                <div class="text-xs text-slate-400 mb-2 flex gap-2" id="breadcrumb"></div>
                <div class="text-xl font-bold text-slate-50" id="nodeTitle" data-i18n="select_asset">Select an asset</div>
                <div class="text-xs text-slate-400 font-mono" id="nodeMeta"></div>
            </div>
            <div class="flex-1 overflow-y-auto p-6" id="pointList"></div>
        </div>
        <div id="emptyView" class="h-full flex flex-col items-center justify-center text-slate-400 opacity-50">
            <i class="fas fa-sitemap text-5xl mb-4"></i>
            <p data-i18n="select_node_hint">Select a node from the tree to view data points</p>
        </div>
    </div>
</div>

@await Html.PartialAsync("_AssetModals")
@Html.AntiForgeryToken()

@section Scripts {
    <environment include="Development">
        <script src="/plswk/js/pages/assets.page.js" type="module"></script>
    </environment>
    <environment exclude="Development">
        <script src="/plswk/dist/js/assets.page.bundle.js" type="module"></script>
    </environment>
}
