{
  // ── InfluxDB ─────────────────────────────────────────────────────────────
  // "influxdb" resolves to the sibling container on the compose network.
  "influxdb": {
    "url": "http://influxdb:8086",
    "token": "connector-token",
    "org": "pulswerk",
    "bucket": "dataPoints"
  },
  "database": {
    "retentionDays": 730,
    "compactionAfterDays": 700,
    "alarmRetentionDays": 30
  },
  "polling": {
    "intervalSeconds": 30
  },
  // ── Server / Web Dashboard ────────────────────────────────────────────────
  "server": {
    "port": 5000,
    "logBufferSize": 5000,
    "auth": {
      "enabled": true,
      "defaultUser": "operator",
      "defaultGroups": [
        "operators"
      ],
      // Trust Docker-internal proxies (compose network)
      "trustedProxies": [
        "172.16.0.0/12",
        "10.0.0.0/8"
      ]
    },
    "rights": {
      "enabled": true,
      "allowAssetValueEdit": [
        "users",
        "admins"
      ],
      "allowAlarmAck": [
        "users",
        "admins"
      ],
      "allowDashboardEdit": [
        "admins"
      ],
      "allowFavoriteEdit": [
        "users",
        "admins"
      ]
    }
  },
  // ── Connections ──────────────────────────────────────────────────────────
  "connections": [
    {
      "id": "modbus-test",
      "type": "modbus-tcp",
      "address": "modbus-sim",
      "port": 502,
      "name": "Modbus Sim 1"
    },
    {
      "id": "modbus-test2",
      "type": "modbus-tcp",
      "address": "modbus-sim2",
      "port": 502,
      "name": "Modbus Sim 2"
    },
    {
      "id": "bacnet-deziko",
      "type": "bacnet-ip",
      "localAddress": "0.0.0.0",
      "localPort": 47809, // different from simulator
      "localDeviceId": 1234,
      "name": "Deziko BACnet"
    }
  ],
  // ── Devices ──────────────────────────────────────────────────────────────
  "devices": [
    {
      "id": "meter-main-a",
      "name": "Main Meter Building A",
      "deviceType": "janitza",
      "connectionId": "modbus-test",
      "deviceId": 1,
      "pollIntervalSeconds": 30,
      "path": [
        "Building A",
        "Main Meter Building A"
      ],
      "assetType": "Meter",
      "dataPoints": [
        {
          "id": "energy_import_consumption_1h",
          "name": "Energie Import stündlich",
          "formula": "energy_import:consumption:1h",
          "units": "kWh"
        },
        {
          "id": "energy_import_consumption_1d",
          "name": "Energie Import täglich",
          "formula": "energy_import:consumption:1d",
          "units": "kWh"
        }
      ]
    },
    {
      "id": "meter-sub-f2",
      "name": "Sub Meter Floor 2",
      "deviceType": "janitza",
      "connectionId": "modbus-test",
      "deviceId": 2,
      "pollIntervalSeconds": 30,
      "path": [
        "Building A",
        "Floor 2",
        "Sub Meter Floor 2"
      ],
      "assetType": "Meter"
    },
    {
      "id": "meter-sub-f3",
      "name": "Sub Meter Floor 3",
      "deviceType": "janitza",
      "connectionId": "modbus-test2",
      "deviceId": 1,
      "pollIntervalSeconds": 30,
      "path": [
        "Building A",
        "Floor 3",
        "Sub Meter Floor 3"
      ],
      "assetType": "Meter"
    },
    {
      "id": "meter-hvac",
      "name": "HVAC Meter",
      "deviceType": "janitza",
      "connectionId": "modbus-test2",
      "deviceId": 2,
      "pollIntervalSeconds": 30,
      "path": [
        "Building A",
        "HVAC",
        "HVAC Meter"
      ],
      "assetType": "Meter"
    },
    {
      "id": "glueck-pv",
      "name": "Glück Controller",
      "deviceType": "glueck",
      "connectionId": "modbus-test",
      "deviceId": 5,
      "pollIntervalSeconds": 30,
      "path": [
        "Building A",
        "PV",
        "Glück Controller"
      ],
      "assetType": "Controller"
    },
    {
      "id": "ahu-test-bacnet",
      "name": "Test BACnet AHU",
      "deviceType": "deziko",
      "connectionId": "bacnet-deziko",
      "deviceId": 10,
      "address": "bacnet-sim",
      "assetType": "BACnet Zone",
      "cov": {
        "enabled": true
      }
    },
    {
      "id": "building_analytics",
      "name": "Building Analytics",
      "deviceType": "virtual",
      "path": [
        "Building A",
        "Analytics"
      ],
      "dataPoints": [
        {
          "id": "total_power",
          "name": "Total Power",
          "formula": "pathsum(\"Building A\", \"*_power\")",
          "units": "kW"
        },
        {
          "id": "hvac_hourly_kwh",
          "name": "HVAC Hourly Consumption",
          "formula": "meter-hvac_energy_import:consumption:1h",
          "units": "kWh/h"
        },
        {
          "id": "building_hourly_kwh",
          "name": "Building Hourly Total",
          "formula": "pathsum(\"Building A\", \"*_energy_import\"):consumption:1h",
          "units": "kWh/h"
        }
      ]
    }
  ]
}